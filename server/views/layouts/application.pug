doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")

    title Task Manager

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    link(rel="stylesheet" href="/assets/styles.css")

  body

    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") Task Manager

        button.navbar-toggler(
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        )
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/session/new") Login
            li.nav-item
              a.nav-link(href="/users/new") Sign Up
            li.nav-item
              a.nav-link(href="/users") Users
            li.nav-item
              a.nav-link(href="/statuses") Statuses
            li.nav-item
              a.nav-link(href="/tasks") Tasks
            li.nav-item
              a.nav-link(href="/labels") Labels

    .container.mt-4
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js")
    script(src="/assets/main.js")