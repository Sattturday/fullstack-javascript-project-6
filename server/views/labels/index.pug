extends ../layouts/application.pug

block content
  h1.mt-5.mb-4= t('views.labels.index.title')

  a.btn.btn-primary.mb-3(href=route('newLabel'))= t('views.labels.index.createLink')
  table.table.table-striped
    thead
      tr
        th= t('views.labels.id')
        th= t('views.labels.name')
        th= t('views.labels.createdAt')
        th= t('views.labels.actions')
    tbody
      each label in labels
        tr
          td= label.id
          td= label.name
          td= formatDate(label.created_at)
          td
            .d-inline-flex.gap-2
              a.btn.btn-sm.btn-primary(href=route('editLabel', { id: label.id }), style="width: 5rem")= t('views.labels.index.edit')
              +buttonTo(route('deleteLabel', { id: label.id }), 'delete')(class="btn btn-sm btn-danger" style="width: 5rem" value=t('views.labels.index.delete'))
