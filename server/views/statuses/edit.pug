extends ../layouts/application.pug

block content
  h1= t('views.statuses.edit.title')

  +formFor()(action=route('updateStatus', { id: status.id }) method='post')
    input(type="hidden" name="_method" value="PATCH")
    +input(status, 'name', errors, 'statuses')(type="text")
    +submit(status)(value=t('views.statuses.edit.submit'))
