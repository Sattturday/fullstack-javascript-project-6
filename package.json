{
  "name": "@hexlet/code",
  "version": "1.0.0",
  "type": "module",
  "description": "Hexlet Task Manager",
  "main": "server/plugin.js",
  "scripts": {
    "start": "fastify start -l info -o server/plugin.js",
    "dev": "fastify start -w -l info -o server/plugin.js --ignore-watch='*.sqlite'",
    "build": "webpack --mode=production",
    "test": "NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/flash": "^5.0.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/passport": "^2.5.0",
    "@fastify/secure-session": "^7.5.1",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@fastify/view": "^9.1.0",
    "bootstrap": "^5.3.0",
    "css-loader": "^7.0.0",
    "fastify": "^4.29.0",
    "fastify-cli": "^6.3.0",
    "fastify-method-override": "^1.5.10",
    "fastify-reverse-routes": "^3.0.0",
    "i18next": "^25.8.18",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^2.9.0",
    "objection": "^3.1.5",
    "objection-unique": "^1.2.2",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "pug": "^3.0.4",
    "qs": "^6.15.0",
    "sqlite3": "^5.1.7",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/helpers/"
    ]
  }
}
